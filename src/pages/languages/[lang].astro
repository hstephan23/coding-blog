---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts, getReadingTime } from '../../utils/posts';
import {
	collectLanguageSlugsFromPosts,
	displayLanguageForSlug,
	postsForLanguageSlug,
} from '../../utils/languages';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const slugs = collectLanguageSlugsFromPosts(posts);
	return slugs.map((lang) => ({
		params: { lang },
		props: { lang },
	}));
}

interface Props {
	lang: string;
}

const { lang } = Astro.props;
const posts = await getPublishedPosts();
const label = displayLanguageForSlug(lang, posts);
const languagePosts = postsForLanguageSlug(lang, posts);
const path = `/languages/${lang}/`;
const postCountLabel =
	languagePosts.length === 1 ? '1 post filed here.' : `${languagePosts.length} posts filed here.`;
---

<BaseLayout
	title={`Language: ${label}`}
	description={`Posts featuring ${label}.`}
	canonicalPath={path}
>
	<div class="site-inner">
		<section class="page-intro surface-card">
			<p class="eyebrow">Language archive</p>
			<h1 class="page-heading">Language: {label}</h1>
			<p class="page-subtitle">{postCountLabel}</p>
			<a class="back-link" href="/languages/">All languages</a>
		</section>
		{
			languagePosts.length === 0 ? (
				<div class="surface-card empty-state">
					<p>No posts for this language yet.</p>
				</div>
			) : (
				<ul class="post-list">
					{languagePosts.map((post) => (
						<li>
							<div class="post-card-top">
								<p class="post-meta">
									<time datetime={post.data.pubDate.toISOString()}>
										{post.data.pubDate.toLocaleDateString('en-US', {
											year: 'numeric',
											month: 'short',
											day: 'numeric',
										})}
									</time>
									<span>{getReadingTime(post.body || '')}</span>
								</p>
							</div>
							<div class="post-card-body">
								<h2>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h2>
								<p class="post-excerpt">{post.data.description}</p>
							</div>
							<div class="post-card-footer">
								<a class="text-link" href={`/blog/${post.id}/`}>Read article</a>
							</div>
						</li>
					))}
				</ul>
			)
		}
	</div>
</BaseLayout>
