---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../utils/posts';
import {
	collectLanguageSlugsFromPosts,
	displayLanguageForSlug,
	postsForLanguageSlug,
} from '../../utils/languages';

const posts = await getPublishedPosts();
const slugs = collectLanguageSlugsFromPosts(posts);
const languagesWithCounts = slugs.map((slug) => ({
	slug,
	label: displayLanguageForSlug(slug, posts),
	count: postsForLanguageSlug(slug, posts).length,
}));
---

<BaseLayout
	title="Languages"
	description="Browse posts by programming language or runtime."
	canonicalPath="/languages/"
>
	<div class="site-inner">
		<section class="page-intro surface-card">
			<p class="eyebrow">Browse by stack</p>
			<h1 class="page-heading">Languages</h1>
			<p class="page-subtitle">
				Explore the archive by language, runtime, and technical focus area.
			</p>
		</section>
		{
			languagesWithCounts.length === 0 ? (
				<div class="surface-card empty-state">
					<p>No languages yet. Add a <code>languages</code> list to post frontmatter.</p>
				</div>
			) : (
				<ul class="collection-grid">
					{languagesWithCounts.map(({ slug, label, count }) => (
						<li>
							<a class="collection-card" href={`/languages/${slug}/`}>
								<span>{label}</span>
								<span class="taxonomy-count">{count}</span>
							</a>
						</li>
					))}
				</ul>
			)
		}
	</div>
</BaseLayout>
