---
import BaseLayout from '../layouts/BaseLayout.astro';
import { slugifyLanguage } from '../utils/languages';
import { getPublishedPosts } from '../utils/posts';

const posts = await getPublishedPosts();
---

<BaseLayout
	title="The Calm Developer"
	description="Notes and snippets with syntax-highlighted code."
	canonicalPath="/"
>
	<div class="site-inner">
		<h1 class="home-heading">Posts</h1>
		<ul class="post-list">
			{
				posts.map((post) => (
					<li>
						<h2>
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						</h2>
						<p class="post-meta">
							<time datetime={post.data.pubDate.toISOString()}>
								{post.data.pubDate.toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</time>
						</p>
						{post.data.languages.length > 0 ? (
							<ul class="post-languages" aria-label="Languages">
								{post.data.languages.map((lang) => (
									<li>
										<a href={`/languages/${slugifyLanguage(lang)}/`}>{lang}</a>
									</li>
								))}
							</ul>
						) : null}
						<p class="post-excerpt">{post.data.description}</p>
					</li>
				))
			}
		</ul>
	</div>
</BaseLayout>

<style>
	.home-heading {
		margin: 0 0 0.5rem;
		font-size: 1.5rem;
		font-weight: 700;
	}
	.post-languages {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 0.75rem;
		margin: 0.35rem 0 0;
		padding: 0;
		list-style: none;
		font-size: 0.85rem;
	}
	.post-languages a {
		color: var(--muted, #666);
	}
</style>
