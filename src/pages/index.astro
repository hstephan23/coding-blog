---
import BaseLayout from '../layouts/BaseLayout.astro';
import { slugifyLanguage } from '../utils/languages';
import { getPublishedPosts, getReadingTime } from '../utils/posts';

const posts = await getPublishedPosts();
const postCount = posts.length;
const languageCount = new Set(posts.flatMap((post) => post.data.languages)).size;
const tagCount = new Set(posts.flatMap((post) => post.data.tags)).size;
const latestPost = posts[0];
const latestHref = latestPost ? `/blog/${latestPost.id}/` : '/about/';
const latestDate = latestPost?.data.pubDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});
---

<BaseLayout
	title="The Calm Developer"
	description="Notes and snippets with syntax-highlighted code."
	canonicalPath="/"
>
	<div class="site-inner">
		<section class="page-hero home-hero">
			<div class="page-hero-copy surface-card">
				<p class="eyebrow">Deliberate software, calm thinking</p>
				<h1 class="page-heading">
					Clear notes for developers who want to understand the machine.
				</h1>
				<p class="page-subtitle">
					A technical blog about C, TypeScript, React, and the practical mechanics
					behind reliable software.
				</p>
				<div class="hero-actions">
					<a class="button-link" href={latestHref}>Read the latest post</a>
					<a class="button-link secondary" href="/about/">About Harrison</a>
				</div>
				<ul class="stat-row" aria-label="Site stats">
					<li>
						<strong>{postCount}</strong>
						<span>published posts</span>
					</li>
					<li>
						<strong>{languageCount}</strong>
						<span>languages covered</span>
					</li>
					<li>
						<strong>{tagCount}</strong>
						<span>topics explored</span>
					</li>
				</ul>
			</div>
			<aside class="surface-card utility-card hero-panel">
				<p class="utility-label">Freshest signal</p>
				{
					latestPost ? (
						<>
							<a class="featured-link" href={latestHref}>{latestPost.data.title}</a>
							<p class="utility-copy">{latestPost.data.description}</p>
							<p class="meta-pill">
								<span>{latestDate}</span>
								<span>{getReadingTime(latestPost.body || '')}</span>
							</p>
						</>
					) : (
						<p class="utility-copy">New writing appears here as it ships.</p>
					)
				}
				<div class="panel-links">
					<a href="/tags/">Browse tags</a>
					<a href="/languages/">Browse languages</a>
				</div>
			</aside>
		</section>

		<section class="section-shell">
			<div class="section-bar">
				<div>
					<p class="eyebrow">Archive</p>
					<h2 class="section-title">All posts</h2>
				</div>
				<p class="section-note">{postCount} published notes</p>
			</div>
			<ul class="post-list">
				{
					posts.map((post) => (
						<li>
							<div class="post-card-top">
								<p class="post-meta">
									<time datetime={post.data.pubDate.toISOString()}>
										{post.data.pubDate.toLocaleDateString('en-US', {
											year: 'numeric',
											month: 'short',
											day: 'numeric',
										})}
									</time>
									<span>{getReadingTime(post.body || '')}</span>
								</p>
								{post.data.languages.length > 0 ? (
									<ul class="post-languages" aria-label="Languages">
										{post.data.languages.map((lang) => (
											<li>
												<a href={`/languages/${slugifyLanguage(lang)}/`}>{lang}</a>
											</li>
										))}
									</ul>
								) : null}
							</div>
							<div class="post-card-body">
								<h2>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h2>
								<p class="post-excerpt">{post.data.description}</p>
							</div>
							<div class="post-card-footer">
								<a class="text-link" href={`/blog/${post.id}/`}>Read article</a>
							</div>
						</li>
					))
				}
			</ul>
		</section>
	</div>
</BaseLayout>
