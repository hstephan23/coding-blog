---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts, getReadingTime } from '../../utils/posts';
import {
	collectTagSlugsFromPosts,
	displayTagForSlug,
	postsForTagSlug,
} from '../../utils/tags';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const slugs = collectTagSlugsFromPosts(posts);
	return slugs.map((tag) => ({
		params: { tag },
		props: { tag },
	}));
}

interface Props {
	tag: string;
}

const { tag } = Astro.props;
const posts = await getPublishedPosts();
const label = displayTagForSlug(tag, posts);
const taggedPosts = postsForTagSlug(tag, posts);
const path = `/tags/${tag}/`;
const postCountLabel =
	taggedPosts.length === 1 ? '1 post filed here.' : `${taggedPosts.length} posts filed here.`;
---

<BaseLayout
	title={`Tag: ${label}`}
	description={`Posts tagged "${label}".`}
	canonicalPath={path}
>
	<div class="site-inner">
		<section class="page-intro surface-card">
			<p class="eyebrow">Topic archive</p>
			<h1 class="page-heading">Tag: {label}</h1>
			<p class="page-subtitle">{postCountLabel}</p>
			<a class="back-link" href="/tags/">All tags</a>
		</section>
		{
			taggedPosts.length === 0 ? (
				<div class="surface-card empty-state">
					<p>No posts with this tag yet.</p>
				</div>
			) : (
				<ul class="post-list">
					{taggedPosts.map((post) => (
						<li>
							<div class="post-card-top">
								<p class="post-meta">
									<time datetime={post.data.pubDate.toISOString()}>
										{post.data.pubDate.toLocaleDateString('en-US', {
											year: 'numeric',
											month: 'short',
											day: 'numeric',
										})}
									</time>
									<span>{getReadingTime(post.body || '')}</span>
								</p>
							</div>
							<div class="post-card-body">
								<h2>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h2>
								<p class="post-excerpt">{post.data.description}</p>
							</div>
							<div class="post-card-footer">
								<a class="text-link" href={`/blog/${post.id}/`}>Read article</a>
							</div>
						</li>
					))}
				</ul>
			)
		}
	</div>
</BaseLayout>
