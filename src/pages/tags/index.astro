---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../utils/posts';
import {
	collectTagSlugsFromPosts,
	displayTagForSlug,
	postsForTagSlug,
} from '../../utils/tags';

const posts = await getPublishedPosts();
const slugs = collectTagSlugsFromPosts(posts);
const tagsWithCounts = slugs.map((slug) => ({
	slug,
	label: displayTagForSlug(slug, posts),
	count: postsForTagSlug(slug, posts).length,
}));
---

<BaseLayout
	title="Tags"
	description="Browse posts by tag."
	canonicalPath="/tags/"
>
	<div class="site-inner">
		<section class="page-intro surface-card">
			<p class="eyebrow">Browse by topic</p>
			<h1 class="page-heading">Tags</h1>
			<p class="page-subtitle">
				Group the archive by themes, ideas, and recurring subjects.
			</p>
		</section>
		{
			tagsWithCounts.length === 0 ? (
				<div class="surface-card empty-state">
					<p>No tags yet.</p>
				</div>
			) : (
				<ul class="collection-grid">
					{tagsWithCounts.map(({ slug, label, count }) => (
						<li>
							<a class="collection-card" href={`/tags/${slug}/`}>
								<span>{label}</span>
								<span class="taxonomy-count">{count}</span>
							</a>
						</li>
					))}
				</ul>
			)
		}
	</div>
</BaseLayout>
