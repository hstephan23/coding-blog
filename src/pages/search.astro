---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Search"
	description="Full-text search across posts."
	canonicalPath="/search/"
>
	<div class="site-inner">
		<section class="page-intro surface-card">
			<p class="eyebrow">Site search</p>
			<h1 class="page-heading">Search the archive</h1>
			<p class="page-subtitle">
				Look through posts, notes, and snippets across the full blog.
			</p>
		</section>
		{
			import.meta.env.DEV ? (
				<div class="notice-card">
					<p>
						The Pagefind index is generated after <code>npm run build</code>. Run
						<code>npm run preview</code> to try search locally.
					</p>
				</div>
			) : (
				<>
					<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
					<div class="search-shell">
						<div id="search" />
					</div>
				</>
			)
		}
	</div>
</BaseLayout>

{!import.meta.env.DEV ? (
	<script is:inline type="module">
		import { PagefindUI } from '/pagefind/pagefind-ui.js';

		new PagefindUI({
			element: '#search',
			showSubResults: true,
		});
	</script>
) : null}
