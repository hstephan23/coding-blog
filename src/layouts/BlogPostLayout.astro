---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import { absoluteUrl } from '../utils/absoluteUrl';
import { slugifyLanguage } from '../utils/languages';
import { slugifyTag } from '../utils/tags';
import { getReadingTime, getRelatedPosts, getPublishedPosts } from '../utils/posts';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const allPosts = await getPublishedPosts();
const relatedPosts = getRelatedPosts(post, allPosts);
const { title, description, pubDate, tags, languages, image } = post.data;
const dateLabel = pubDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
const readingTime = getReadingTime(post.body || '');
const path = `/blog/${post.id}/`;
const site = Astro.site ?? new URL('https://example.com');
const postUrl = new URL(path, site).href;
const defaultOgPath =
	(import.meta.env.PUBLIC_OG_IMAGE as string | undefined)?.trim() ||
	'/apple-touch-icon.png';

let schemaImage: string;
if (image) {
	if (typeof image === 'string') {
		schemaImage = absoluteUrl(site, image);
	} else {
		schemaImage = absoluteUrl(site, image.src);
	}
} else {
	schemaImage = absoluteUrl(site, defaultOgPath);
}

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	url: postUrl,
	image: schemaImage,
};

const giscusRepo = import.meta.env.PUBLIC_GISCUS_REPO as string | undefined;
const giscusRepoId = import.meta.env.PUBLIC_GISCUS_REPO_ID as string | undefined;
const giscusCategoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID as
	| string
	| undefined;
const giscusCategory =
	(import.meta.env.PUBLIC_GISCUS_CATEGORY as string | undefined) ?? 'Comments';
const showGiscus =
	Boolean(giscusRepo) &&
	Boolean(giscusRepoId) &&
	Boolean(giscusCategoryId);
---

<BaseLayout
	title={title}
	description={description}
	canonicalPath={path}
	image={image}
	ogType="article"
	jsonLd={jsonLd}
>
	<article class="prose post-article">
		<header>
			<p class="eyebrow">Article</p>
			<h1>{title}</h1>
			<p class="post-meta">
				<time datetime={pubDate.toISOString()}>{dateLabel}</time>
				<span>{readingTime}</span>
			</p>
			{
				languages.length > 0 ? (
					<ul class="tags languages" aria-label="Languages">
						{languages.map((lang) => (
							<li>
								<a href={`/languages/${slugifyLanguage(lang)}/`}>{lang}</a>
							</li>
						))}
					</ul>
				) : null
			}
			{
				tags.length > 0 ? (
					<ul class="tags" aria-label="Tags">
						{tags.map((tag) => (
							<li>
								<a href={`/tags/${slugifyTag(tag)}/`}>{tag}</a>
							</li>
						))}
					</ul>
				) : null
			}
			{
				image && typeof image !== 'string' ? (
					<Image
						src={image}
						alt={title}
						class="post-image"
						width={1200}
						height={630}
					/>
				) : null
			}
		</header>
		<slot />
		<footer class="post-footer">
			<a class="text-link" href="/">Back to posts</a>
		</footer>
		{
			relatedPosts.length > 0 ? (
				<section class="related-posts" aria-labelledby="related-heading">
					<h2 id="related-heading">Related Posts</h2>
					<ul class="related-list">
						{relatedPosts.map((relatedPost) => (
							<li class="related-item">
								<a href={`/blog/${relatedPost.id}/`}>{relatedPost.data.title}</a>
								<time datetime={relatedPost.data.pubDate.toISOString()}>
									{relatedPost.data.pubDate.toLocaleDateString('en-US', {
										year: 'numeric',
										month: 'short',
										day: 'numeric',
									})}
								</time>
							</li>
						))}
					</ul>
				</section>
			) : null
		}
		{
			showGiscus ? (
				<section class="giscus" aria-label="Comments">
					<h2 class="giscus-heading">Comments</h2>
					<script
						is:inline
						src="https://giscus.app/client.js"
						data-repo={giscusRepo}
						data-repo-id={giscusRepoId}
						data-category={giscusCategory}
						data-category-id={giscusCategoryId}
						data-mapping="pathname"
						data-strict="0"
						data-reactions-enabled="1"
						data-emit-metadata="0"
						data-input-position="bottom"
						data-theme="preferred_color_scheme"
						data-lang="en"
						crossorigin="anonymous"
						async
					/>
				</section>
			) : null
		}
	</article>
</BaseLayout>
